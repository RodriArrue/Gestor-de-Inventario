# ===================================
# Gestor de Inventario — Variables de entorno
# ===================================
# Copiar este archivo como .env y completar los valores

# App
NODE_ENV=development
PORT=3001

# Base de datos (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=gestor_inventario
DB_USER=postgres
DB_PASSWORD=postgres

# JWT (clave compartida con el Gestor de Usuarios)
JWT_SECRET=tu_clave_secreta_jwt_aqui
