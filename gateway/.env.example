# ===================================
# API Gateway — Variables de entorno
# ===================================
# Copiar este archivo como .env y completar los valores

# App
PORT=8080

# URLs de los servicios upstream
USUARIOS_SERVICE_URL=http://localhost:3000
INVENTARIO_SERVICE_URL=http://localhost:3001

# JWT (clave compartida con los microservicios)
JWT_SECRET=tu_clave_secreta_jwt_aqui
